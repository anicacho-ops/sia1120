# ─────────────────────────────────────────────────────────────
# 시아 (icqa) 환경변수 템플릿
# 이 파일을 복사해 .env.local 을 만들고 실제 값을 채우세요.
#   cp .env.example .env.local
# .env.local 은 git에 커밋되지 않습니다 (.gitignore).
# ─────────────────────────────────────────────────────────────

# ── OpenAI ──────────────────────────────────────────────────
# LLM / 임베딩 호출용. https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Supabase ────────────────────────────────────────────────
# 프로젝트 대시보드 > Project Settings > API 에서 확인
# NEXT_PUBLIC_* 값은 브라우저에 노출됩니다 (anon key까지만).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role 키는 서버 전용 — 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=

# ── RAG 설정 (PRD 섹션 9.4) ─────────────────────────────────
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35

# ── 앱 ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
